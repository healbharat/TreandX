{
  "hosting": {
    "public": "out",
    "cleanUrls": true,
    "trailingSlash": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/post/**",
        "destination": "/post/index.html"
      },
      {
        "source": "/profile/analytics/**",
        "destination": "/profile/analytics/index.html"
      },
      {
        "source": "/profile/**",
        "destination": "/profile/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
